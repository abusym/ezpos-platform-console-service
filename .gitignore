### Spring Boot config (keep secrets out of git) ###
# Committable in this repo:
!src/main/resources/application.yaml
!src/main/resources/application-prod.yaml
!src/main/resources/application-*.example.yaml

# Not committable (contains env-specific / secrets)
src/main/resources/application-dev.yaml
src/main/resources/application-staging.yaml

# Common local/override patterns (opt-in locally, never commit)
src/main/resources/application-local.yaml
src/main/resources/application-local.yml
src/main/resources/application-*.local.yaml
src/main/resources/application-*.local.yml
src/main/resources/application-*.override.yaml
src/main/resources/application-*.override.yml
src/main/resources/application-*.private.yaml
src/main/resources/application-*.private.yml
src/main/resources/application-*.secret.yaml
src/main/resources/application-*.secret.yml

# Local env files
.env
.env.*
